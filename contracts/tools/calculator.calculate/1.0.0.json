{
  "toolId": "calculator.calculate",
  "name": "calculator",
  "version": "1.0.0",
  "description": "Calculate arithmetic over supplied numeric values.\n\nAccepts numeric literals with arithmetic operators and parentheses. It does\nnot retrieve current or external facts, solve symbolic equations, perform\ncalculus, or mutate external state. Returns {ok: True, value} on success or\n{ok: False, error: {kind, message, retryable}} on failure.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
      "expression": {
        "description": "Parameter expression",
        "type": "string"
      }
    },
    "required": [
      "expression"
    ],
    "type": "object"
  },
  "outputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "oneOf": [
      {
        "type": "object",
        "properties": {
          "ok": {
            "const": true
          },
          "value": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "ok",
          "value"
        ],
        "additionalProperties": false
      },
      {
        "type": "object",
        "properties": {
          "ok": {
            "const": false
          },
          "error": {
            "type": "object",
            "properties": {
              "kind": {
                "const": "bad_input"
              },
              "message": {
                "type": "string",
                "minLength": 1
              },
              "retryable": {
                "type": "boolean"
              }
            },
            "required": [
              "kind",
              "message",
              "retryable"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "ok",
          "error"
        ],
        "additionalProperties": false
      }
    ]
  },
  "failureModes": [
    "bad_input"
  ],
  "sideEffects": "none",
  "resultTrust": "trusted_structured",
  "latencyBudgetMs": 100
}

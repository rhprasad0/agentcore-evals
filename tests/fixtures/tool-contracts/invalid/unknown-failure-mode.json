{
  "toolId": "example.lookup",
  "version": "1.0.0",
  "description": "Look up a synthetic example record. Does not write or cause external side effects.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "query"
    ],
    "additionalProperties": false
  },
  "outputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "oneOf": [
      {
        "type": "object",
        "properties": {
          "ok": {
            "const": true
          },
          "value": {
            "type": "string"
          }
        },
        "required": [
          "ok",
          "value"
        ],
        "additionalProperties": false
      },
      {
        "type": "object",
        "properties": {
          "ok": {
            "const": false
          },
          "error": {
            "type": "object",
            "properties": {
              "kind": {
                "const": "bad_input"
              },
              "message": {
                "type": "string",
                "minLength": 1
              },
              "retryable": {
                "type": "boolean"
              }
            },
            "required": [
              "kind",
              "message",
              "retryable"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "ok",
          "error"
        ],
        "additionalProperties": false
      }
    ]
  },
  "failureModes": [
    "rate_limited"
  ],
  "sideEffects": "none",
  "resultTrust": "trusted_structured",
  "latencyBudgetMs": 100
}

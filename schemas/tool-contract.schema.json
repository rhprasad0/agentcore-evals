{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentcore-evals:schema:tool-contract:1.0.0",
  "$defs": {
    "embeddedSchema": {
      "type": "object",
      "$ref": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "$schema": {
          "const": "https://json-schema.org/draft/2020-12/schema"
        }
      },
      "required": [
        "$schema"
      ]
    }
  },
  "type": "object",
  "properties": {
    "toolId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9_]*)+$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-((?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$",
      "not": {
        "pattern": "[\\r\\n]"
      }
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "inputSchema": {
      "$ref": "#/$defs/embeddedSchema"
    },
    "outputSchema": {
      "$ref": "#/$defs/embeddedSchema"
    },
    "failureModes": {
      "type": "array",
      "items": {
        "enum": [
          "bad_input",
          "auth",
          "upstream_4xx",
          "upstream_5xx",
          "timeout",
          "network"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "sideEffects": {
      "enum": [
        "none",
        "read_external",
        "write_external"
      ]
    },
    "resultTrust": {
      "enum": [
        "trusted_structured",
        "untrusted_external"
      ]
    },
    "authScope": {
      "type": "string",
      "minLength": 1
    },
    "latencyBudgetMs": {
      "type": "integer",
      "minimum": 1
    }
  },
  "required": [
    "toolId",
    "version",
    "description",
    "inputSchema",
    "outputSchema",
    "failureModes",
    "sideEffects",
    "resultTrust",
    "latencyBudgetMs"
  ],
  "additionalProperties": false
}

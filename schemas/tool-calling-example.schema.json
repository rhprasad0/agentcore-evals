{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentcore-evals:schema:tool-calling-example:1.0.0",
  "$defs": {
    "toolId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9_]*)+$"
    },
    "argConstraint": {
      "type": "object",
      "properties": {
        "toolId": {
          "$ref": "#/$defs/toolId"
        },
        "path": {
          "type": "string",
          "pattern": "^\\$\\.[A-Za-z_][A-Za-z0-9_]*$"
        },
        "equals": true,
        "inSet": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true
        },
        "coversExactlyOnce": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true
        },
        "absent": {
          "const": true
        },
        "notContains": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "toolId",
        "path"
      ],
      "oneOf": [
        {
          "required": ["equals"]
        },
        {
          "required": ["inSet"]
        },
        {
          "required": ["coversExactlyOnce"]
        },
        {
          "required": ["absent"]
        },
        {
          "required": ["notContains"]
        }
      ],
      "additionalProperties": false
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "failureKind": {
      "enum": [
        "bad_input",
        "auth",
        "upstream_4xx",
        "upstream_5xx",
        "timeout",
        "network"
      ]
    },
    "failureInjection": {
      "type": "object",
      "properties": {
        "toolId": {
          "$ref": "#/$defs/toolId"
        },
        "kind": {
          "$ref": "#/$defs/failureKind"
        },
        "retryable": {
          "type": "boolean"
        },
        "source": {
          "enum": [
            "input",
            "provider",
            "transport",
            "gateway",
            "tool"
          ]
        },
        "providerCode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "occurrence": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "toolId",
        "kind",
        "retryable"
      ],
      "additionalProperties": false
    }
  },
  "type": "object",
  "properties": {
    "exampleId": {
      "type": "string",
      "pattern": "^tc-[0-9]{4}$"
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "scenarioFamily": {
      "enum": [
        "straightforward",
        "multi-call",
        "no-tool",
        "failure-injection",
        "adversarial-ambiguous",
        "dependency-stop"
      ]
    },
    "expected": {
      "type": "object",
      "properties": {
        "toolIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/toolId"
          },
          "uniqueItems": true
        },
        "minCalls": {
          "type": "integer",
          "minimum": 0
        },
        "maxCalls": {
          "type": "integer",
          "minimum": 0
        },
        "argConstraints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/argConstraint"
          }
        },
        "mustNotCall": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/toolId"
          },
          "uniqueItems": true
        },
        "responseMust": {
          "$ref": "#/$defs/stringList"
        },
        "responseMustNot": {
          "$ref": "#/$defs/stringList"
        }
      },
      "required": [
        "toolIds",
        "minCalls",
        "maxCalls",
        "argConstraints",
        "mustNotCall",
        "responseMust",
        "responseMustNot"
      ],
      "additionalProperties": false
    },
    "failureInjection": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/failureInjection"
        }
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "enum": [
          "weather",
          "calculator",
          "search",
          "single-tool",
          "comparison",
          "direct-answer",
          "decline",
          "near-boundary",
          "retryable",
          "non-retryable",
          "ambiguity",
          "forced-choice",
          "untrusted-result",
          "canary",
          "dependency",
          "stop-on-failure",
          "no-fabrication",
          "unit-conversion"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "provenance": {
      "type": "object",
      "properties": {
        "authoringMethod": {
          "enum": [
            "hand-authored",
            "generated"
          ]
        },
        "reviewStatus": {
          "enum": [
            "pending",
            "reviewed"
          ]
        }
      },
      "required": [
        "authoringMethod",
        "reviewStatus"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "exampleId",
    "prompt",
    "scenarioFamily",
    "expected",
    "failureInjection",
    "tags",
    "provenance"
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentcore-evals:schema:tool-calling-dataset-manifest:1.0.0",
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-((?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$",
      "not": {
        "pattern": "[\\r\\n]"
      }
    },
    "namespacedId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9_]*)+$"
    },
    "manifestRef": {
      "type": "object",
      "properties": {
        "manifestId": {
          "$ref": "#/$defs/namespacedId"
        },
        "version": {
          "$ref": "#/$defs/semver"
        }
      },
      "required": [
        "manifestId",
        "version"
      ],
      "additionalProperties": false
    },
    "toolRef": {
      "type": "object",
      "properties": {
        "toolId": {
          "$ref": "#/$defs/namespacedId"
        },
        "version": {
          "$ref": "#/$defs/semver"
        }
      },
      "required": [
        "toolId",
        "version"
      ],
      "additionalProperties": false
    },
    "artifactPath": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_.-]+(?:/[a-zA-Z0-9_.-]+)+$"
    }
  },
  "type": "object",
  "properties": {
    "datasetId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "$ref": "#/$defs/semver"
    },
    "schemaVersion": {
      "$ref": "#/$defs/semver"
    },
    "taxonomyVersion": {
      "$ref": "#/$defs/semver"
    },
    "agentManifest": {
      "$ref": "#/$defs/manifestRef"
    },
    "toolContracts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/toolRef"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "corpusPath": {
      "$ref": "#/$defs/artifactPath"
    },
    "expectedRowCount": {
      "type": "integer",
      "minimum": 1
    },
    "distribution": {
      "type": "object",
      "properties": {
        "straightforward": {
          "type": "integer",
          "minimum": 0
        },
        "multi-call": {
          "type": "integer",
          "minimum": 0
        },
        "no-tool": {
          "type": "integer",
          "minimum": 0
        },
        "failure-injection": {
          "type": "integer",
          "minimum": 0
        },
        "adversarial-ambiguous": {
          "type": "integer",
          "minimum": 0
        },
        "dependency-stop": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "straightforward",
        "multi-call",
        "no-tool",
        "failure-injection",
        "adversarial-ambiguous",
        "dependency-stop"
      ],
      "additionalProperties": false
    },
    "canonicalCanary": {
      "const": "INJECTION_CANARY_DO_NOT_FOLLOW"
    },
    "generationPromptPath": {
      "$ref": "#/$defs/artifactPath"
    },
    "editorialChecklistPath": {
      "$ref": "#/$defs/artifactPath"
    },
    "reviewStatus": {
      "enum": [
        "draft",
        "human-reviewed"
      ]
    }
  },
  "required": [
    "datasetId",
    "version",
    "schemaVersion",
    "taxonomyVersion",
    "agentManifest",
    "toolContracts",
    "corpusPath",
    "expectedRowCount",
    "distribution",
    "canonicalCanary",
    "generationPromptPath",
    "editorialChecklistPath",
    "reviewStatus"
  ],
  "additionalProperties": false
}

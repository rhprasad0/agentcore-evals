{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentcore-evals:schema:execution-trace:1.0.0",
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-((?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$",
      "not": {
        "pattern": "[\\r\\n]"
      }
    },
    "traceId": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$"
    },
    "spanId": {
      "type": "string",
      "pattern": "^[0-9a-f]{16}$"
    },
    "toolId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9_]*)+$"
    },
    "toolReference": {
      "type": "object",
      "properties": {
        "toolId": {"$ref": "#/$defs/toolId"},
        "contractVersion": {"$ref": "#/$defs/semver"}
      },
      "required": ["toolId", "contractVersion"],
      "additionalProperties": false
    },
    "diagnostic": {
      "type": "object",
      "properties": {
        "source": {
          "enum": ["input", "provider", "transport", "gateway", "tool"]
        },
        "code": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 64
        }
      },
      "required": ["source", "code"],
      "additionalProperties": false
    },
    "toolResult": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "output": {},
        "failureKind": {
          "type": ["string", "null"],
          "enum": [null, "bad_input", "auth", "upstream_4xx", "upstream_5xx", "timeout", "network"]
        },
        "retryable": {"type": ["boolean", "null"]},
        "diagnostic": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/diagnostic"}
          ]
        }
      },
      "required": ["ok", "output", "failureKind", "retryable", "diagnostic"],
      "allOf": [
        {
          "if": {"properties": {"ok": {"const": true}}, "required": ["ok"]},
          "then": {
            "properties": {
              "failureKind": {"type": "null"},
              "retryable": {"type": "null"}
            }
          },
          "else": {
            "properties": {
              "failureKind": {"type": "string"},
              "retryable": {"type": "boolean"}
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "tokenUsage": {
      "type": "object",
      "properties": {
        "input": {"type": "integer", "minimum": 0},
        "output": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 0}
      },
      "required": ["input", "output", "total"],
      "additionalProperties": false
    },
    "span": {
      "type": "object",
      "properties": {
        "sequence": {"type": "integer", "minimum": 0},
        "spanId": {"$ref": "#/$defs/spanId"},
        "parentSpanId": {
          "oneOf": [{"type": "null"}, {"$ref": "#/$defs/spanId"}]
        },
        "operationName": {"enum": ["invoke_agent", "execute_tool", "chat"]},
        "observedToolName": {"type": ["string", "null"], "minLength": 1},
        "tool": {
          "oneOf": [{"type": "null"}, {"$ref": "#/$defs/toolReference"}]
        },
        "arguments": {"type": ["object", "null"]},
        "result": {
          "oneOf": [{"type": "null"}, {"$ref": "#/$defs/toolResult"}]
        },
        "selectionReasoning": {"type": ["string", "null"], "minLength": 1},
        "startTimeUnixNano": {"type": "integer", "minimum": 0},
        "endTimeUnixNano": {"type": "integer", "minimum": 0},
        "latencyMs": {"type": "number", "minimum": 0},
        "tokenUsage": {
          "oneOf": [{"type": "null"}, {"$ref": "#/$defs/tokenUsage"}]
        }
      },
      "required": [
        "sequence", "spanId", "parentSpanId", "operationName",
        "observedToolName", "tool", "arguments", "result",
        "selectionReasoning", "startTimeUnixNano", "endTimeUnixNano",
        "latencyMs", "tokenUsage"
      ],
      "allOf": [
        {
          "if": {
            "properties": {"operationName": {"const": "execute_tool"}},
            "required": ["operationName"]
          },
          "then": {
            "properties": {
              "observedToolName": {"type": "string"},
              "tool": {"$ref": "#/$defs/toolReference"},
              "arguments": {"type": "object"},
              "result": {"$ref": "#/$defs/toolResult"}
            }
          },
          "else": {
            "properties": {
              "observedToolName": {"type": "null"},
              "tool": {"type": "null"},
              "arguments": {"type": "null"},
              "result": {"type": "null"}
            }
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "type": "object",
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "canonicalizerVersion": {"const": "1.0.0"},
    "sourceProfile": {
      "type": "object",
      "properties": {
        "name": {"enum": ["strands-inline", "strands-adot-split"]},
        "producer": {
          "type": "object",
          "properties": {
            "name": {"const": "strands-agents"},
            "version": {"$ref": "#/$defs/semver"}
          },
          "required": ["name", "version"],
          "additionalProperties": false
        },
        "instrumentationScope": {
          "type": "object",
          "properties": {
            "name": {"const": "strands.telemetry.tracer"},
            "version": {"type": ["string", "null"]},
            "schemaUrl": {"type": ["string", "null"], "format": "uri"}
          },
          "required": ["name", "version", "schemaUrl"],
          "additionalProperties": false
        },
        "collector": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "properties": {
                "name": {"const": "aws-opentelemetry-distro"},
                "version": {"$ref": "#/$defs/semver"}
              },
              "required": ["name", "version"],
              "additionalProperties": false
            }
          ]
        }
      },
      "required": ["name", "producer", "instrumentationScope", "collector"],
      "additionalProperties": false
    },
    "sessionId": {"type": "string", "minLength": 1},
    "traceId": {"$ref": "#/$defs/traceId"},
    "agentManifest": {
      "type": "object",
      "properties": {
        "manifestId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9_]*)+$"
        },
        "version": {"$ref": "#/$defs/semver"}
      },
      "required": ["manifestId", "version"],
      "additionalProperties": false
    },
    "prompt": {"type": "string", "minLength": 1},
    "response": {"type": "string", "minLength": 1},
    "spans": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/span"}
    }
  },
  "required": [
    "schemaVersion", "canonicalizerVersion", "sourceProfile", "sessionId",
    "traceId", "agentManifest", "prompt", "response", "spans"
  ],
  "additionalProperties": false
}
